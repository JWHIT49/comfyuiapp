# Copy this file to ".env" and adjust as needed.

# Where ComfyUI is running. If the backend runs on the same machine as
# ComfyUI, leave this as-is. If ComfyUI is on another box/cloud GPU, set the
# reachable address, e.g. http://192.168.1.50:8188
COMFYUI_URL=http://127.0.0.1:8188

# API-format workflow template used for every edit.
WORKFLOW_PATH=workflows/flux_kontext_edit.json

# CORS origins allowed to call this API ("*" is fine for local development).
CORS_ORIGINS=*
