{
  "expo": {
    "name": "ComfyUI Image Edit",
    "slug": "comfyui-image-edit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b1020"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jwhit49.comfyuiimageedit",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "This app needs access to your photos so you can pick an image to edit.",
        "NSCameraUsageDescription": "This app needs camera access so you can take a photo to edit."
      }
    },
    "android": {
      "package": "com.jwhit49.comfyuiimageedit",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0b1020"
      }
    },
    "plugins": [
      "expo-image-picker"
    ],
    "extra": {
      "apiBaseUrl": "http://192.168.68.54:8000"
    }
  }
}
